# script_tools_native.gd - Script Tools原生实现
# 根据godot-dev-guide添加完整的类型提示
# 注意：.gd文件是完整的GDScript程序代码（不是.tscn/.tres格式）

@tool
class_name ScriptToolsNative
extends RefCounted

# ============================================================================
# 工具注册
# ============================================================================

static func register_tools(server_core: RefCounted) -> void:
	# 注册list_project_scripts工具
	_register_list_project_scripts(server_core)
	
	# 注册read_script工具
	_register_read_script(server_core)
	
	# 注册create_script工具
	_register_create_script(server_core)
	
	# 注册modify_script工具
	_register_modify_script(server_core)
	
	# 注册analyze_script工具
	_register_analyze_script(server_core)

# ============================================================================
# list_project_scripts - 列出项目中的所有脚本
# ============================================================================

static func _register_list_project_scripts(server_core: RefCounted) -> void:
	var tool_name: String = "list_project_scripts"
	var description: String = "List all GDScript files (.gd) in the project. Returns paths relative to res://."
	
	# inputSchema
	var input_schema: Dictionary = {
		"type": "object",
		"properties": {
			"search_path": {
				"type": "string",
				"description": "Optional subpath to search (e.g. 'res://scripts/'). Default is 'res://'.",
				"default": "res://"
			}
		}
	}
	
	# outputSchema
	var output_schema: Dictionary = {
		"type": "object",
		"properties": {
			"scripts": {
				"type": "array",
				"items": {"type": "string"}
			},
			"count": {"type": "integer"}
		}
	}
	
	# annotations - readOnlyHint = true
	var annotations: Dictionary = {
		"readOnlyHint": true,
		"destructiveHint": false,
		"idempotentHint": true,
		"openWorldHint": false
	}
	
	# 注册工具
	var instance = ScriptToolsNative.new()
	server_core.register_tool(tool_name, description, input_schema,
						  Callable(instance, "_tool_list_project_scripts"),
						  output_schema, annotations)

static func _tool_list_project_scripts(params: Dictionary) -> Dictionary:
	# 参数提取
	var search_path: String = params.get("search_path", "res://")
	
	# 验证路径安全性
	if not search_path.begins_with("res://") and not search_path.begins_with("user://"):
		return {"error": "Invalid path. Only res:// and user:// are allowed"}
	
	# 标准化路径
	if not search_path.ends_with("/"):
		search_path += "/"
	
	# 使用DirAccess递归查找所有.gd文件
	var scripts: Array[String] = []
	_collect_scripts(search_path, scripts)
	
	# 排序
	scripts.sort()
	
	return {
		"scripts": scripts,
		"count": scripts.size()
	}

# 辅助函数：递归收集脚本文件
static func _collect_scripts(directory_path: String, result: Array[String]) -> void:
	var dir: DirAccess = DirAccess.open(directory_path)
	
	if not dir:
		return
	
	# 列出所有文件和目录
	dir.list_dir_begin()
	var file_name: String = dir.get_next()
	
	while not file_name.is_empty():
		# 跳过特殊目录
		if file_name != "." and file_name != "..":
			var full_path: String = directory_path + "/" + file_name
			
			if dir.current_is_dir():
				# 递归处理子目录
				_collect_scripts(full_path, result)
			elif file_name.ends_with(".gd"):
				# 添加脚本文件
				result.append(full_path)
		
		file_name = dir.get_next()
	
	dir.list_dir_end()

# ============================================================================
# read_script - 读取脚本内容
# ============================================================================

static func _register_read_script(server_core: RefCounted) -> void:
	var tool_name: String = "read_script"
	var description: String = "Read the content of a GDScript file (.gd). Returns the complete script source code."
	
	# inputSchema
	var input_schema: Dictionary = {
		"type": "object",
		"properties": {
			"script_path": {
				"type": "string",
				"description": "Path to the script file (e.g. 'res://scripts/player.gd')"
			}
		},
		"required": ["script_path"]
	}
	
	# outputSchema
	var output_schema: Dictionary = {
		"type": "object",
		"properties": {
			"script_path": {"type": "string"},
			"content": {"type": "string"},
			"line_count": {"type": "integer"}
		}
	}
	
	# annotations - readOnlyHint = true
	var annotations: Dictionary = {
		"readOnlyHint": true,
		"destructiveHint": false,
		"idempotentHint": true,
		"openWorldHint": false
	}
	
	# 注册工具
	var instance = ScriptToolsNative.new()
	server_core.register_tool(tool_name, description, input_schema,
						  Callable(instance, "_tool_read_script"),
						  output_schema, annotations)

static func _tool_read_script(params: Dictionary) -> Dictionary:
	# 参数提取
	var script_path: String = params.get("script_path", "")
	
	if script_path.is_empty():
		return {"error": "Missing required parameter: script_path"}
	
	# 验证路径安全性（根据mcp-builder安全最佳实践）
	if not script_path.begins_with("res://") and not script_path.begins_with("user://"):
		return {"error": "Invalid path. Only res:// and user:// are allowed"}
	
	# 验证文件扩展名
	if not script_path.ends_with(".gd"):
		return {"error": "Not a GDScript file (.gd): " + script_path}
	
	# 使用FileAccess读取文件（根据godot-dev-guide）
	if not FileAccess.file_exists(script_path):
		return {"error": "File not found: " + script_path}
	
	var file: FileAccess = FileAccess.open(script_path, FileAccess.READ)
	
	if not file:
		return {"error": "Failed to open file: " + script_path}
	
	# 读取内容
	var content: String = ""
	var line_count: int = 0
	
	while not file.eof_reached():
		var line: String = file.get_line()
		content += line + "\n"
		line_count += 1
	
	file.close()
	
	# 移除最后一个多余的换行符
	if not content.is_empty():
		content = content.trim_suffix("\n")
	
	return {
		"script_path": script_path,
		"content": content,
		"line_count": line_count
	}

# ============================================================================
# create_script - 创建新脚本
# ============================================================================

static func _register_create_script(server_core: RefCounted) -> void:
	var tool_name: String = "create_script"
	var description: String = "Create a new GDScript file with optional template. GDScript files are complete programs, not resource files."
	
	# inputSchema
	var input_schema: Dictionary = {
		"type": "object",
		"properties": {
			"script_path": {
				"type": "string",
				"description": "Path where the script will be saved (e.g. 'res://scripts/player.gd')"
			},
			"content": {
				"type": "string",
				"description": "Optional initial content for the script. If not provided, creates an empty script."
			},
			"template": {
				"type": "string",
				"description": "Optional template to use: 'empty', 'node', 'characterbody2d', 'characterbody3d', 'area2d', 'area3d'. Default is 'empty'."
			}
		},
		"required": ["script_path"]
	}
	
	# outputSchema
	var output_schema: Dictionary = {
		"type": "object",
		"properties": {
			"status": {"type": "string"},
			"script_path": {"type": "string"},
			"line_count": {"type": "integer"}
		}
	}
	
	# annotations
	var annotations: Dictionary = {
		"readOnlyHint": false,
		"destructiveHint": false,
		"idempotentHint": false,
		"openWorldHint": false
	}
	
	# 注册工具
	var instance = ScriptToolsNative.new()
	server_core.register_tool(tool_name, description, input_schema,
						  Callable(instance, "_tool_create_script"),
						  output_schema, annotations)

static func _tool_create_script(params: Dictionary) -> Dictionary:
	# 参数提取
	var script_path: String = params.get("script_path", "")
	var content: String = params.get("content", "")
	var template: String = params.get("template", "empty")
	
	# 参数验证
	if script_path.is_empty():
		return {"error": "Missing required parameter: script_path"}
	
	# 验证路径安全性
	if not script_path.begins_with("res://") and not script_path.begins_with("user://"):
		return {"error": "Invalid path. Only res:// and user:// are allowed"}
	
	# 验证文件扩展名
	if not script_path.ends_with(".gd"):
		script_path += ".gd"
	
	# 检查文件是否已存在
	if FileAccess.file_exists(script_path):
		return {"error": "File already exists: " + script_path}
	
	# 如果没有提供内容，使用模板
	if content.is_empty():
		content = _get_script_template(template)
	
	# 写入文件
	var file: FileAccess = FileAccess.open(script_path, FileAccess.WRITE)
	
	if not file:
		return {"error": "Failed to create file: " + script_path}
	
	file.store_string(content)
	file.close()
	
	# 计算行数
	var line_count: int = content.split("\n").size()
	
	return {
		"status": "success",
		"script_path": script_path,
		"line_count": line_count
	}

# 辅助函数：获取脚本模板
static func _get_script_template(template_name: String) -> String:
	match template_name:
		"node":
			return """@tool
extends Node

# Called when the node enters the scene tree
func _ready() -> void:
	pass

# Called every frame
func _process(delta: float) -> void:
	pass
"""
		"characterbody2d":
			return """@tool
extends CharacterBody2D

func _physics_process(delta: float) -> void:
	move_and_slide()
"""
		"characterbody3d":
			return """@tool
extends CharacterBody3D

func _physics_process(delta: float) -> void:
	move_and_slide()
"""
		"area2d":
			return """@tool
extends Area2D

func _ready() -> void:
	body_entered.connect(_on_body_entered)

func _on_body_entered(body: Node) -> void:
	pass
"""
		"area3d":
			return """@tool
extends Area3D

func _ready() -> void:
	body_entered.connect(_on_body_entered)

func _on_body_entered(body: Node3D) -> void:
	pass
"""
		_:# empty 或其他
			return ""


# ============================================================================
# modify_script - 修改脚本内容
# ============================================================================

static func _register_modify_script(server_core: RefCounted) -> void:
	var tool_name: String = "modify_script"
	var description: String = "Modify the content of an existing GDScript file. Can replace entire content or specific lines."
	
	# inputSchema
	var input_schema: Dictionary = {
		"type": "object",
		"properties": {
			"script_path": {
				"type": "string",
				"description": "Path to the script file to modify (e.g. 'res://scripts/player.gd')"
			},
			"content": {
				"type": "string",
				"description": "New content for the script (full replacement)"
			},
			"line_number": {
				"type": "integer",
				"description": "Optional line number to replace (1-indexed). If provided with 'content', replaces that line only."
			}
		},
		"required": ["script_path", "content"]
	}
	
	# outputSchema
	var output_schema: Dictionary = {
		"type": "object",
		"properties": {
			"status": {"type": "string"},
			"script_path": {"type": "string"},
			"line_count": {"type": "integer"}
		}
	}
	
	# annotations - destructiveHint = true
	var annotations: Dictionary = {
		"readOnlyHint": false,
		"destructiveHint": true,  # 会覆盖文件
		"idempotentHint": false,
		"openWorldHint": false
	}
	
	# 注册工具
	var instance = ScriptToolsNative.new()
	server_core.register_tool(tool_name, description, input_schema,
						  Callable(instance, "_tool_modify_script"),
						  output_schema, annotations)

static func _tool_modify_script(params: Dictionary) -> Dictionary:
	# 参数提取
	var script_path: String = params.get("script_path", "")
	var new_content: String = params.get("content", "")
	var line_number: int = params.get("line_number", 0)
	
	# 参数验证
	if script_path.is_empty():
		return {"error": "Missing required parameter: script_path"}
	if new_content.is_empty():
		return {"error": "Missing required parameter: content"}
	
	# 验证路径安全性
	if not script_path.begins_with("res://") and not script_path.begins_with("user://"):
		return {"error": "Invalid path. Only res:// and user:// are allowed"}
	
	# 验证文件扩展名
	if not script_path.ends_with(".gd"):
		return {"error": "Not a GDScript file (.gd): " + script_path}
	
	# 验证文件是否存在
	if not FileAccess.file_exists(script_path):
		return {"error": "File not found: " + script_path}
	
	# 读取现有内容
	var file: FileAccess = FileAccess.open(script_path, FileAccess.READ)
	if not file:
		return {"error": "Failed to open file for reading: " + script_path}
	
	var existing_lines: PackedStringArray = []
	while not file.eof_reached():
		existing_lines.append(file.get_line())
	file.close()
	
	# 修改内容
	var final_content: String
	
	if line_number > 0 and line_number <= existing_lines.size():
		# 替换特定行
		existing_lines[line_number - 1] = new_content
		final_content = "\n".join(existing_lines)
	else:
		# 全量替换
		final_content = new_content
	
	# 写入文件
	file = FileAccess.open(script_path, FileAccess.WRITE)
	if not file:
		return {"error": "Failed to open file for writing: " + script_path}
	
	file.store_string(final_content)
	file.close()
	
	# 计算行数
	var line_count: int = final_content.split("\n").size()
	
	return {
		"status": "success",
		"script_path": script_path,
		"line_count": line_count
	}

# ============================================================================
# analyze_script - 分析脚本结构
# ============================================================================

static func _register_analyze_script(server_core: RefCounted) -> void:
	var tool_name: String = "analyze_script"
	var description: String = "Analyze the structure of a GDScript file. Returns class name, methods, signals, and properties."
	
	# inputSchema
	var input_schema: Dictionary = {
		"type": "object",
		"properties": {
			"script_path": {
				"type": "string",
				"description": "Path to the script file to analyze (e.g. 'res://scripts/player.gd')"
			}
		},
		"required": ["script_path"]
	}
	
	# outputSchema
	var output_schema: Dictionary = {
		"type": "object",
		"properties": {
			"script_path": {"type": "string"},
			"class_name": {"type": "string"},
			"extends": {"type": "string"},
			"methods": {"type": "array"},
			"signals": {"type": "array"},
			"properties": {"type": "array"},
			"line_count": {"type": "integer"}
		}
	}
	
	# annotations - readOnlyHint = true
	var annotations: Dictionary = {
		"readOnlyHint": true,
		"destructiveHint": false,
		"idempotentHint": true,
		"openWorldHint": false
	}
	
	# 注册工具
	var instance = ScriptToolsNative.new()
	server_core.register_tool(tool_name, description, input_schema,
						  Callable(instance, "_tool_analyze_script"),
						  output_schema, annotations)

static func _tool_analyze_script(params: Dictionary) -> Dictionary:
	# 参数提取
	var script_path: String = params.get("script_path", "")
	
	# 参数验证
	if script_path.is_empty():
		return {"error": "Missing required parameter: script_path"}
	
	# 验证路径安全性
	if not script_path.begins_with("res://") and not script_path.begins_with("user://"):
		return {"error": "Invalid path. Only res:// and user:// are allowed"}
	
	# 验证文件扩展名
	if not script_path.ends_with(".gd"):
		return {"error": "Not a GDScript file (.gd): " + script_path}
	
	# 验证文件是否存在
	if not FileAccess.file_exists(script_path):
		return {"error": "File not found: " + script_path}
	
	# 读取脚本内容
	var file: FileAccess = FileAccess.open(script_path, FileAccess.READ)
	if not file:
		return {"error": "Failed to open file: " + script_path}
	
	var content: String = ""
	var line_count: int = 0
	var lines: PackedStringArray = []
	
	while not file.eof_reached():
		var line: String = file.get_line()
		lines.append(line)
		content += line + "\n"
		line_count += 1
	
	file.close()
	
	# 解析脚本结构
	var class_name: String = ""
	var extends_from: String = ""
	var methods: Array = []
	var signals: Array[String] = []
	var properties: Array = []
	
	# 简单文本解析（GDScript语法）
	for line in lines:
		var trimmed: String = line.strip_edges()
		
		# 解析class_name
		if trimmed.begins_with("class_name "):
			class_name = trimmed.split(" ")[1]
		
		# 解析extends
		elif trimmed.begins_with("extends "):
			extends_from = trimmed.split(" ")[1]
		
		# 解析signals
		elif trimmed.begins_with("signal "):
			var signal_name: String = trimmed.split(" ")[1].split("(")[0]
			signals.append(signal_name)
		
		# 解析方法
		elif trimmed.begins_with("func "):
			var method_info: Dictionary = _parse_method_signature(trimmed)
			if method_info:
				methods.append(method_info)
		
		# 解析属性（简单变量）
		elif trimmed.begins_with("var ") or trimmed.begins_with("const "):
			var prop_info: Dictionary = _parse_property_declaration(trimmed)
			if prop_info:
				properties.append(prop_info)
	
	# 尝试使用Godot的内省API（如果脚本可以加载）
	# 注意：这可能需要脚本没有语法错误
	var script_resource: Resource = load(script_path)
	if script_resource and script_resource is GDScript:
		var gd_script: GDScript = script_resource
		
		# 获取方法列表（使用Object的get_method_list）
		# 注意：这只能获取GDScript定义的方法，不包括父类
		
		# 对于更详细的分析，我们使用文本解析的结果
	
	return {
		"script_path": script_path,
		"class_name": class_name,
		"extends": extends_from,
		"methods": methods,
		"signals": signals,
		"properties": properties,
		"line_count": line_count
	}

# 辅助函数：解析方法签名
static func _parse_method_signature(line: String) -> Dictionary:
	# 移除"func "前缀
	var signature: String = line.substr(5)
	
	# 提取方法名和参数
	var paren_start: int = signature.find("(")
	var paren_end: int = signature.find(")")
	
	if paren_start == -1 or paren_end == -1:
		return {}
	
	var method_name: String = signature.substr(0, paren_start).strip_edges()
	var params_str: String = signature.substr(paren_start + 1, paren_end - paren_start - 1)
	
	# 解析参数
	var parameters: Array[Dictionary] = []
	if not params_str.is_empty():
		var params: PackedStringArray = params_str.split(",")
		for param in params:
			var param_info: PackedStringArray = param.strip_edges().split(":")
			var param_dict: Dictionary = {"name": param_info[0].strip_edges()}
			if param_info.size() > 1:
				param_dict["type"] = param_info[1].strip_edges()
			parameters.append(param_dict)
	
	# 检查返回值类型
	var return_type: String = ""
	var arrow_pos: int = signature.find("->")
	if arrow_pos != -1:
		var after_arrow: String = signature.substr(arrow_pos + 2)
		var colon_pos: int = after_arrow.find(":")
		if colon_pos != -1:
			return_type = after_arrow.substr(0, colon_pos).strip_edges()
		else:
			# 简化：取第一个token
			return_type = after_arrow.split(" ")[0].strip_edges()
	
	return {
		"name": method_name,
		"parameters": parameters,
		"return_type": return_type
	}

# 辅助函数：解析属性声明
static func _parse_property_declaration(line: String) -> Dictionary:
	var is_const: bool = line.begins_with("const ")
	var prefix_len: int = 6 if is_const else 4
	
	# 移除"var "或"const "前缀
	var declaration: String = line.substr(prefix_len)
	
	# 提取属性名
	var space_pos: int = declaration.find(" ")
	var colon_pos: int = declaration.find(":")
	var eq_pos: int = declaration.find("=")
	
	var prop_name: String = ""
	if space_pos != -1:
		prop_name = declaration.substr(0, space_pos).strip_edges()
	elif colon_pos != -1:
		prop_name = declaration.substr(0, colon_pos).strip_edges()
	elif eq_pos != -1:
		prop_name = declaration.substr(0, eq_pos).strip_edges()
	else:
		prop_name = declaration.strip_edges()
	
	# 提取类型（如果有）
	var prop_type: String = ""
	if colon_pos != -1 and eq_pos != -1:
		prop_type = declaration.substr(colon_pos + 1, eq_pos - colon_pos - 1).strip_edges()
	elif colon_pos != -1:
		prop_type = declaration.substr(colon_pos + 1).strip_edges()
	
	return {
		"name": prop_name,
		"type": prop_type,
		"is_const": is_const
	}
